# Copy to .env and fill in.  .env is git-ignored.
# Either set ANTHROPIC_API_KEY here OR keep Anthropic_API_KEY.json next to config.py.

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_MAX_TOKENS=512

# Optional - default DB name and DB storage dir
DEFAULT_DB=data
DB_DIR=/app/databases
